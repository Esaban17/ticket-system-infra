# Terraform state — local state may contain sensitive resource attributes
# (RDS endpoints, IAM ARNs, hashed passwords). Main workspace state lives in
# the remote S3 backend starting in Delivery 2. Bootstrap workspace state
# (infra/bootstrap/terraform.tfstate) is intentionally committed — see the
# delivery-2 summary for the rationale.
terraform.tfstate
terraform.tfstate.backup
!infra/bootstrap/terraform.tfstate
!infra/bootstrap/terraform.tfstate.backup

# Terraform working directory
.terraform/
.terraform.lock.hcl
*Zone.Identifier

# Plan files (binary, not human-readable, generated on demand)
tfplan
*.tfplan

# Variable files that may contain secrets
# (dev.tfvars is committed intentionally — it contains no secrets)
*.auto.tfvars
secrets.tfvars

# OS artifacts
.DS_Store
Thumbs.db

# Editor artifacts
.idea/
.vscode/
*.swp

# Claude Code local config (not part of the project)
.claude/

# Generated Lambda zip (rebuilt by archive_file data source on each plan)
infra/modules/compute/build/
