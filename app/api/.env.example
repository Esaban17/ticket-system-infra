# ============================================================
# Ticket System API — Variables de entorno
# Copiar a .env (nunca commitear .env con valores reales)
# ============================================================

# --- Servidor ---
PORT=8080
NODE_ENV=development

# --- Base de datos (Postgres) ---
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL=

# --- JWT ---
JWT_SECRET=
JWT_EXPIRES_IN=3600s

# --- Logging ---
# Niveles: error | warn | log | debug | verbose
LOG_LEVEL=log

# --- CORS ---
# Lista separada por comas de orígenes permitidos
CORS_ORIGINS=http://localhost:3000

# --- AWS (para workers Lambda y S3 adjuntos) ---
AWS_REGION=
AWS_S3_BUCKET_ATTACHMENTS=

# --- SLA (valores en minutos) ---
SLA_CRITICAL_MINUTES=60
SLA_HIGH_MINUTES=240
SLA_MEDIUM_MINUTES=480
SLA_LOW_MINUTES=1440
